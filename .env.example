# =============================================================================
# Telegram bot
# =============================================================================
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# =============================================================================
# AI provider (OpenAI-compatible)
# =============================================================================
# The bot works with any provider exposing OpenAI's /v1/chat/completions
# endpoint. Pick one of the example configurations below.

# --- Option 1: OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL is unset → defaults to https://api.openai.com/v1

# --- Option 2: Groq (free tier, fastest inference) ---
# OPENAI_API_KEY=gsk_...
# OPENAI_MODEL=llama-3.3-70b-versatile
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# --- Option 3: Together AI ---
# OPENAI_API_KEY=...
# OPENAI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
# OPENAI_BASE_URL=https://api.together.xyz/v1

# --- Option 4: OpenRouter (250+ models, unified billing) ---
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_MODEL=anthropic/claude-3.5-sonnet
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Option 5: Local Ollama (runs on your machine, no API costs) ---
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=llama3.1:8b
# OPENAI_BASE_URL=http://localhost:11434/v1

# Tuning
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.7

# =============================================================================
# Function calling (customer support tools)
# =============================================================================
# Enables the demo support tools defined in src/bot/tools.py:
#   • lookup_order(order_id)
#   • reset_password_link(email)
#   • escalate_to_human(reason, priority)
# Customize tools.py to wire them to your real backend (orders API, auth
# service, ticketing system).
ENABLE_FUNCTION_CALLING=false

# =============================================================================
# Storage & limits
# =============================================================================
REDIS_URL=redis://localhost:6379/0
MAX_CONVERSATION_LENGTH=20
RATE_LIMIT_PER_MINUTE=10
DEFAULT_SYSTEM_PROMPT=You are a helpful AI assistant. Be concise and informative.

# =============================================================================
# Operations
# =============================================================================
HEALTH_CHECK_PORT=8080
LOG_LEVEL=INFO
