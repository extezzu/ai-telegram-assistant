# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key (get from platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Max tokens in OpenAI response (default: 1024)
OPENAI_MAX_TOKENS=1024

# Temperature for OpenAI responses (0.0-2.0, default: 0.7)
OPENAI_TEMPERATURE=0.7

# Redis URL (default: redis://localhost:6379/0)
REDIS_URL=redis://localhost:6379/0

# Conversation memory length per user (default: 20)
MAX_CONVERSATION_LENGTH=20

# Rate limiting: max messages per user per minute (default: 10)
RATE_LIMIT_PER_MINUTE=10

# Default system prompt for the AI assistant
DEFAULT_SYSTEM_PROMPT=You are a helpful AI assistant. Be concise and informative.

# Health check server port (default: 8080)
HEALTH_CHECK_PORT=8080

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
